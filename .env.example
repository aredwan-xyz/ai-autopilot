# ============================================================
# AI BUSINESS AUTOPILOT — Environment Configuration
# Copy this file to .env and fill in your credentials
# ============================================================

# --- LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
DEFAULT_LLM_PROVIDER=anthropic          # anthropic | openai
DEFAULT_MODEL=claude-opus-4-5           # Model slug

# --- App Settings ---
APP_ENV=development                     # development | production
APP_SECRET_KEY=change-me-to-random-secret
LOG_LEVEL=INFO
DASHBOARD_PORT=8000

# --- Database ---
DATABASE_URL=sqlite:///./autopilot.db   # or postgresql://user:pass@host/db

# --- Redis (for Celery task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- Gmail / Google Workspace ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_CREDENTIALS_FILE=credentials/google_token.json

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=#autopilot-alerts

# --- Notion ---
NOTION_API_KEY=secret_your-notion-key
NOTION_DATABASE_ID_LEADS=
NOTION_DATABASE_ID_CONTENT=
NOTION_DATABASE_ID_REPORTS=

# --- HubSpot CRM ---
HUBSPOT_ACCESS_TOKEN=pat-na1-your-token
HUBSPOT_PORTAL_ID=

# --- Airtable ---
AIRTABLE_API_KEY=pat-your-key
AIRTABLE_BASE_ID=app-your-base-id

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# --- LinkedIn (for content publishing) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# --- Twitter/X ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- Email Settings ---
EMAIL_TRIAGE_INTERVAL_MINUTES=15
EMAIL_AUTO_REPLY_ENABLED=true
EMAIL_ESCALATION_SLACK_CHANNEL=#urgent

# --- Lead Agent ---
LEAD_MIN_SCORE=65
LEAD_CRM_TARGET=hubspot                 # hubspot | airtable | notion

# --- Content Agent ---
CONTENT_PUBLISH_PLATFORMS=linkedin,twitter
CONTENT_QUEUE_NOTION_DB=

# --- Report Agent ---
REPORT_RECIPIENTS=you@company.com
REPORT_SCHEDULE=weekly                  # weekly | monthly | both
REPORT_OUTPUT_DIR=./reports

# --- Invoice Agent ---
INVOICE_OVERDUE_DAYS=14
INVOICE_CRITICAL_AMOUNT=5000
INVOICE_FOLLOWUP_TEMPLATE=templates/invoice_followup.md

# --- Notifications ---
ALERT_EMAIL=you@company.com
ALERT_SLACK_ENABLED=true
